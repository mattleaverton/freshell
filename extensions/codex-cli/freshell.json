{
  "name": "codex",
  "version": "1.0.0",
  "label": "Codex CLI",
  "description": "OpenAI's Codex CLI agent",
  "category": "cli",
  "cli": {
    "command": "codex",
    "envVar": "CODEX_CMD",
    "resumeArgs": ["resume", "{{sessionId}}"],
    "supportsModel": true,
    "supportsSandbox": true
  },
  "picker": {
    "shortcut": "X",
    "group": "agents"
  }
}
